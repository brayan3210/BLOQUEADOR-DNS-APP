<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Tema base (day / claro). Los tokens de color se resuelven por modo. -->
    <style name="Theme.FiltroContenido" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/brand_blue</item>
        <item name="colorPrimaryVariant">@color/brand_blue</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/gold</item>
        <item name="colorOnSecondary">@color/navy</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/on_surface</item>
        <item name="android:colorBackground">@color/bg</item>
        <item name="android:windowBackground">@color/bg</item>
        <item name="android:statusBarColor">@color/bg</item>
        <item name="android:navigationBarColor">@color/bg</item>
        <!-- Iconos oscuros de la barra de estado en modo claro -->
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <!-- Botones dorados (CTA principal) con texto navy -->
    <style name="Widget.Filtro.GoldButton" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@null</item>
        <item name="android:background">@drawable/bg_gold_button</item>
        <item name="android:textColor">#0B1220</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.02</item>
        <item name="android:textAllCaps">false</item>
        <item name="elevation">0dp</item>
        <item name="rippleColor">#33000000</item>
    </style>
</resources>
